{
	"name": "app",
	"version": "0.0.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "svelte-kit sync && svelte-package && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "pnpm run lint:eslint && pnpm run lint:svelte",
		"lint:svelte": "svelte-check",
		"lint:eslint": "eslint --cache --concurrency auto",
		"fmt": "prettier . --experimental-cli --check --cache-location .prettiercache",
		"fmt:fix": "prettier . --experimental-cli --write --cache-location .prettiercache",
		"test:unit": "vitest",
		"test:playwright": "playwright test --config=playwright.config.ts"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.5",
		"@eslint/js": "^9.39.4",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-vercel": "^5.7.0",
		"@sveltejs/kit": "^2.50.1",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.4",
		"@types/node": "^24.12.2",
		"@vite-pwa/sveltekit": "^1.1.0",
		"@vitest/browser-playwright": "^4.1.5",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"flowbite": "^4.0.1",
		"flowbite-svelte": "^1.33.1",
		"flowbite-svelte-icons": "^3.1.0",
		"globals": "^17.5.0",
		"playwright": "^1.59.1",
		"playwright-extra": "^4.3.6",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"publint": "^0.3.18",
		"puppeteer-extra-plugin-stealth": "^2.11.2",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.59.0",
		"vite": "^7.3.2",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-plugin-pwa": "^1.2.0",
		"vitest": "^4.1.5",
		"vitest-browser-svelte": "^2.1.1"
	},
	"keywords": [
		"svelte"
	],
	"packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
	"dependencies": {
		"@googlemaps/js-api-loader": "^2.0.2",
		"@supabase/ssr": "^0.8.0",
		"@supabase/supabase-js": "^2.104.0",
		"@sveltejs/kit": "^2.57.1",
		"dotenv": "^17.4.2",
		"workbox-window": "^7.4.0"
	}
}
